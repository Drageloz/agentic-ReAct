# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: openai | claude | langchain
# langchain → uses ChatOpenAI via LangChain (satisfies the prueba técnica requirement)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Anthropic Claude (used when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── RAG Provider ───────────────────────────────────────────────────────────────
# Options: simulated | chroma
# simulated → keyword TF-IDF (no external API, works offline)
# chroma    → ChromaDB + OpenAI Embeddings (real vector store with metadata filtering)
RAG_PROVIDER=chroma

LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# ── Application ────────────────────────────────────────────────────────────────
DEBUG=false
API_PREFIX=/api/v1
AGENT_MAX_ITERATIONS=10

# ── Database (SQL Server) ──────────────────────────────────────────────────────
# Local dev (docker-compose): MSSQL_HOST=db
# Azure prod: MSSQL_HOST=<sql-server-name>.database.windows.net
MSSQL_HOST=db
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=React4as2#Strong!
MSSQL_DATABASE=react_db
# ODBC driver — must match what's installed in the container/host
# Docker image uses: "ODBC Driver 18 for SQL Server"
MSSQL_DRIVER=ODBC Driver 18 for SQL Server

# ── Security ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-a-long-random-string
API_KEY_HEADER=X-API-Key
# Comma-separated list of valid API keys
VALID_API_KEYS=["dev-key-12345","test-key-67890"]

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60

